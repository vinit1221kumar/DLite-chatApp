# D-LITE production example env (host-level / compose-level)
# Prefer editing each service's .env inside its folder for secrets.

NODE_ENV=production

# Public ports
GATEWAY_PORT=4000

# CORS / origins (set to your domain)
CORS_ORIGINS=https://app.example.com
GATEWAY_CORS_ORIGIN=https://app.example.com

# Frontend public config (build args)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_CHAT_SOCKET_URL=https://api.example.com/chat
NEXT_PUBLIC_CALL_SOCKET_URL=https://api.example.com/call
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

